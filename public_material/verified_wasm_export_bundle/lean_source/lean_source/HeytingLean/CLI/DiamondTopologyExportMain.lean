/-! ## CLI Main -/

private partial def parseArgs (args : List String) (cfg : Config := {}) : IO (Config × Bool) :=
  match args with
  | [] => pure (cfg, false)
  | "--" :: rest => parseArgs rest cfg
  | "--help" :: _ => pure (cfg, true)
  | "--out" :: dir :: rest => parseArgs rest { cfg with outDir := dir }
  | "--no-cab" :: rest => parseArgs rest { cfg with generateCAB := false }
  | "--cab" :: rest => parseArgs rest { cfg with generateCAB := true }
  | x :: _ => throw <| IO.userError s!"unknown arg: {x} (try --help)"

private def resolveOutDir (dir : String) : IO System.FilePath := do
  if dir.startsWith "/" then
    return System.FilePath.mk dir
  let cwd ← IO.currentDir
  let base :=
    if cwd.fileName == some "lean" then
      cwd.parent.getD cwd
    else
      cwd
  return base / dir

private def writeFile (path : System.FilePath) (contents : String) : IO Unit := do
  let some parent := path.parent
    | throw <| IO.userError s!"could not compute parent directory for {path}"
  IO.FS.createDirAll parent
  IO.FS.writeFile path contents

def main (argv : List String) : IO UInt32 := do
  try
    let (cfg, showHelp) ← parseArgs argv
    if showHelp then
      IO.println usage
      return (0 : UInt32)

    let outDir ← resolveOutDir cfg.outDir

    let diamondCPath := outDir / "diamond.c"
    let diamondHPath := outDir / "diamond.h"
    let driverCPath := outDir / "driver.c"
    let expectedPath := outDir / "expected.txt"
    let provenancePath := outDir / "provenance.json"

    writeFile diamondHPath headerSource
    writeFile diamondCPath sourceCode
    writeFile driverCPath driverSource
    writeFile expectedPath expectedOutput
    writeFile provenancePath provenanceJson

    IO.println s!"[diamond_topology_export] wrote {diamondHPath}"
    IO.println s!"[diamond_topology_export] wrote {diamondCPath}"
    IO.println s!"[diamond_topology_export] wrote {driverCPath}"
    IO.println s!"[diamond_topology_export] wrote {expectedPath}"
    IO.println s!"[diamond_topology_export] wrote {provenancePath}"

    -- Generate CAB certificate if enabled
    if cfg.generateCAB then
      let artifacts : List HeytingLean.Meta.LeanTT0.ExportCAB.Artifact := [
        { name := "diamond.h", content := headerSource },
        { name := "diamond.c", content := sourceCode },
        { name := "driver.c", content := driverSource },
        { name := "expected.txt", content := expectedOutput },
        { name := "provenance.json", content := provenanceJson }
      ]
      let theorems := [
        "Diamond.le_refl",
        "Diamond.le_trans",
        "Diamond.le_antisymm",
        "Diamond.inf_le_left",
        "Diamond.inf_le_right",
        "Diamond.le_inf",
        "Diamond.le_sup_left",
        "Diamond.le_sup_right",
        "Diamond.sup_le",
        "Diamond.le_himp_iff",
        "Diamond.himp_bot",
        "OmegaComputable.countValidNuclei"
      ]
      let leanModules := [
        "HeytingLean.Tests.Bridges.ComputableTestKit",
        "HeytingLean.Tests.Bridges.OmegaComputable"
      ]
      let certificate := HeytingLean.Meta.LeanTT0.ExportCAB.generateCertificate
        "diamond"
        artifacts
        theorems
        leanModules
        "Verified Diamond Heyting algebra operations exported to C"
      let certPath := outDir / "certificate.json"
      writeFile certPath (Lean.Json.pretty certificate)
      IO.println s!"[diamond_topology_export] wrote {certPath}"

    IO.println ""
    IO.println "To build and test:"
    IO.println s!"  cd {outDir}"
    IO.println "  cc -o driver driver.c diamond.c"
    IO.println "  ./driver"
    IO.println "  diff <(./driver) expected.txt && echo 'VERIFIED OK'"
    if cfg.generateCAB then
      IO.println ""
      IO.println "To verify CAB certificate:"
      IO.println s!"  lake exe cab_verify_export {outDir}/certificate.json"

    return (0 : UInt32)
  catch e =>
    IO.eprintln s!"[diamond_topology_export] error: {e}"
    return (1 : UInt32)

end DiamondTopologyExport
end CLI
end HeytingLean

def main (args : List String) : IO UInt32 :=
  HeytingLean.CLI.DiamondTopologyExport.main args
