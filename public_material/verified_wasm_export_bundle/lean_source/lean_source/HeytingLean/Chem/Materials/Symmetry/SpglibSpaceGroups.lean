        op3 (mat3Z (-1) 0 0 0 0 (-1) 0 (-1) 0) (vec3 ((-1 : ℚ) / 4) ((-1 : ℚ) / 4) ((-1 : ℚ) / 4)),
        op3 (mat3Z 1 0 0 0 0 1 0 1 0) (vec3 ((-1 : ℚ) / 4) ((-1 : ℚ) / 4) ((-1 : ℚ) / 4)),
        op3 (mat3Z 0 1 0 0 0 (-1) (-1) 0 0) (vec3 ((-1 : ℚ) / 2) ((-1 : ℚ) / 2) (0 : ℚ)),
        op3 (mat3Z 0 (-1) 0 0 0 1 1 0 0) (vec3 ((-1 : ℚ) / 2) ((-1 : ℚ) / 2) (0 : ℚ)),
        op3 (mat3Z 1 0 0 0 0 (-1) 0 1 0) (vec3 ((1 : ℚ) / 4) ((1 : ℚ) / 4) ((-1 : ℚ) / 4)),
        op3 (mat3Z (-1) 0 0 0 0 1 0 (-1) 0) (vec3 ((1 : ℚ) / 4) ((1 : ℚ) / 4) ((-1 : ℚ) / 4)),
      ]
    },
  ]

def byNumber? (n : Nat) : Option Entry :=
  if h : 1 ≤ n ∧ n ≤ table.size then
    have hn : n - 1 < table.size := by
      cases n with
      | zero =>
          cases (Nat.not_succ_le_zero 0 (by simpa using h.1))
      | succ k =>
          -- `n-1 = k` and `k < size` follows from `k+1 ≤ size`.
          simpa using (Nat.lt_of_succ_le h.2)
    some (table[n - 1])
  else
    none

def spaceGroupData? (n : Nat) : Option (SpaceGroupData 3) :=
  (byNumber? n).map (fun e => { label := e.internationalShort, ops := e.ops })

