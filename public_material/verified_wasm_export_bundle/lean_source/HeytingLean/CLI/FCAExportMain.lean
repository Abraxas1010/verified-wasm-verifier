import HeytingLean.Tests.Bridges.FCAComputable
import HeytingLean.Tests.Bridges.ComputableTestKit
import HeytingLean.Meta.LeanTT0.ExportCAB

/-!
# `fca_export` - Formal Concept Analysis to C

Exports FCA operations for concept validity checking and lattice operations.

## Output Files

- `fca.c`           - C implementation
- `fca.h`           - C ABI header
- `fca_driver.c`    - Test driver
- `expected.txt`    - Expected output
- `provenance.json` - Theorem provenance
- `fca_wrapper.py`  - Python FFI wrapper

## Use Case

Given a binary data matrix (objects × attributes), verify:
1. Is a claimed pattern a valid formal concept?
2. What is the meet/join of two concepts?
3. What is the closure of a set of objects/attributes?

-/

namespace HeytingLean
namespace CLI
namespace FCAExport

open HeytingLean.Tests.Bridges.ComputableTestKit
open HeytingLean.Tests.Bridges.FCAComputable

/-! ## Configuration -/

structure Config where
  outDir : String := "dist/fca_export"
  generateCAB : Bool := true
deriving Repr

private def usage : String :=
  String.intercalate "\n"
    [ "fca_export"
    , ""
    , "Exports verified Formal Concept Analysis operations to C + Python."
    , ""
    , "Output files:"
    , "  - fca.c            (C source)"
    , "  - fca.h            (C header)"
    , "  - fca_driver.c     (test driver)"
    , "  - expected.txt     (expected output)"
    , "  - provenance.json  (theorem chain)"
    , "  - fca_wrapper.py   (Python FFI)"
    , "  - certificate.json (CAB certificate with Merkle root)"
    , ""
    , "Flags:"
    , "  --out <dir>    output directory"
    , "  --no-cab       skip CAB certificate generation"
    , "  --help         show this message"
    ]

