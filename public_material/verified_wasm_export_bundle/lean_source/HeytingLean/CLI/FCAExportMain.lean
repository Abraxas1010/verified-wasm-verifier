private def pythonWrapper : String :=
  String.intercalate "\n"
    [ "#!/usr/bin/env python3"
    , "\"\"\""
    , "Formal Concept Analysis - Python Wrapper"
    , ""
    , "Wraps the verified C implementation of FCA operations."
    , "Provenance: HeytingLean.Tests.Bridges.FCAComputable"
    , "\"\"\""
    , ""
    , "import ctypes"
    , "import os"
    , "from pathlib import Path"
    , "from typing import Set, Tuple, Optional"
    , ""
    , "# Load the shared library"
    , "_lib_path = Path(__file__).parent / \"libfca.so\""
    , "if not _lib_path.exists():"
    , "    # Try to build it"
    , "    os.system(f\"cd {_lib_path.parent} && cc -shared -fPIC -o libfca.so fca.c\")"
    , ""
    , "_lib = ctypes.CDLL(str(_lib_path))"
    , ""
    , "# Configure function signatures"
    , "_lib.fca_incidence.argtypes = [ctypes.c_int, ctypes.c_int]"
    , "_lib.fca_incidence.restype = ctypes.c_int"
    , ""
    , "_lib.fca_obj_deriv.argtypes = [ctypes.c_int]"
    , "_lib.fca_obj_deriv.restype = ctypes.c_int"
    , ""
    , "_lib.fca_attr_deriv.argtypes = [ctypes.c_int]"
    , "_lib.fca_attr_deriv.restype = ctypes.c_int"
    , ""
    , "_lib.fca_obj_closure.argtypes = [ctypes.c_int]"
    , "_lib.fca_obj_closure.restype = ctypes.c_int"
    , ""
    , "_lib.fca_is_valid_concept.argtypes = [ctypes.c_int, ctypes.c_int]"
    , "_lib.fca_is_valid_concept.restype = ctypes.c_int"
    , ""
    , "_lib.fca_concept_meet.argtypes = [ctypes.c_int, ctypes.c_int]"
    , "_lib.fca_concept_meet.restype = ctypes.c_int"
    , ""
    , "_lib.fca_concept_join.argtypes = [ctypes.c_int, ctypes.c_int]"
    , "_lib.fca_concept_join.restype = ctypes.c_int"
    , ""
    , "_lib.fca_concept_himp.argtypes = [ctypes.c_int, ctypes.c_int]"
    , "_lib.fca_concept_himp.restype = ctypes.c_int"
    , ""
    , "_lib.fca_concept_name.argtypes = [ctypes.c_int]"
    , "_lib.fca_concept_name.restype = ctypes.c_char_p"
    , ""
    , "# Object/Attribute encoding"
    , "OBJ_A, OBJ_B = 0, 1"
    , "ATTR_X, ATTR_Y = 0, 1"
    , ""
    , "# Concept encoding (Diamond isomorphism)"
    , "CONCEPT_BOT = 0    # extent={}, intent={X,Y}"
    , "CONCEPT_LEFT = 1   # extent={a}, intent={X}"
    , "CONCEPT_RIGHT = 2  # extent={b}, intent={Y}"
    , "CONCEPT_TOP = 3    # extent={a,b}, intent={}"
    , ""
    , ""
    , "def _set_to_bitmask(s: Set[int]) -> int:"
    , "    \"\"\"Convert set of indices to bitmask.\"\"\""
    , "    return sum(1 << i for i in s)"
    , ""
    , ""
    , "def _bitmask_to_set(mask: int, size: int = 2) -> Set[int]:"
    , "    \"\"\"Convert bitmask to set of indices.\"\"\""
    , "    return {i for i in range(size) if mask & (1 << i)}"
    , ""
    , ""
    , "class FormalContext:"
    , "    \"\"\""
    , "    A formal context with verified operations."
    , "    "
    , "    This implementation uses C code generated from Lean proofs,"
    , "    ensuring all operations satisfy the Heyting algebra axioms."
    , "    \"\"\""
    , "    "
    , "    OBJECTS = {'a': OBJ_A, 'b': OBJ_B}"
    , "    ATTRIBUTES = {'X': ATTR_X, 'Y': ATTR_Y}"
    , "    "
    , "    def incidence(self, obj: str, attr: str) -> bool:"
    , "        \"\"\"Check if object has attribute.\"\"\""
    , "        o = self.OBJECTS.get(obj, -1)"
    , "        a = self.ATTRIBUTES.get(attr, -1)"
    , "        return bool(_lib.fca_incidence(o, a))"
    , "    "
    , "    def obj_deriv(self, objects: Set[str]) -> Set[str]:"
    , "        \"\"\"Object derivation: attributes common to all objects.\"\"\""
    , "        obj_mask = _set_to_bitmask({self.OBJECTS[o] for o in objects})"
    , "        attr_mask = _lib.fca_obj_deriv(obj_mask)"
    , "        return {a for a, i in self.ATTRIBUTES.items() if attr_mask & (1 << i)}"
    , "    "
    , "    def attr_deriv(self, attributes: Set[str]) -> Set[str]:"
    , "        \"\"\"Attribute derivation: objects having all attributes.\"\"\""
    , "        attr_mask = _set_to_bitmask({self.ATTRIBUTES[a] for a in attributes})"
    , "        obj_mask = _lib.fca_attr_deriv(attr_mask)"
    , "        return {o for o, i in self.OBJECTS.items() if obj_mask & (1 << i)}"
    , "    "
    , "    def closure(self, objects: Set[str]) -> Set[str]:"
    , "        \"\"\"Closure operator: G'' = (G')'\"\"\""
    , "        obj_mask = _set_to_bitmask({self.OBJECTS[o] for o in objects})"
    , "        closed_mask = _lib.fca_obj_closure(obj_mask)"
    , "        return {o for o, i in self.OBJECTS.items() if closed_mask & (1 << i)}"
    , "    "
    , "    def is_valid_concept(self, extent: Set[str], intent: Set[str]) -> bool:"
    , "        \"\"\"Check if (extent, intent) is a valid formal concept.\"\"\""
    , "        obj_mask = _set_to_bitmask({self.OBJECTS[o] for o in extent})"
    , "        attr_mask = _set_to_bitmask({self.ATTRIBUTES[a] for a in intent})"
    , "        return bool(_lib.fca_is_valid_concept(obj_mask, attr_mask))"
    , ""
    , ""
    , "class Concept:"
    , "    \"\"\"A formal concept with lattice operations.\"\"\""
    , "    "
    , "    def __init__(self, code: int):"
    , "        self._code = code"
    , "    "
    , "    @classmethod"
    , "    def bot(cls) -> 'Concept':"
    , "        return cls(CONCEPT_BOT)"
    , "    "
    , "    @classmethod"
    , "    def left(cls) -> 'Concept':"
    , "        return cls(CONCEPT_LEFT)"
    , "    "
    , "    @classmethod"
    , "    def right(cls) -> 'Concept':"
    , "        return cls(CONCEPT_RIGHT)"
    , "    "
    , "    @classmethod"
    , "    def top(cls) -> 'Concept':"
    , "        return cls(CONCEPT_TOP)"
    , "    "
    , "    def __and__(self, other: 'Concept') -> 'Concept':"
    , "        \"\"\"Meet operation (⊓).\"\"\""
    , "        return Concept(_lib.fca_concept_meet(self._code, other._code))"
    , "    "
    , "    def __or__(self, other: 'Concept') -> 'Concept':"
    , "        \"\"\"Join operation (⊔).\"\"\""
    , "        return Concept(_lib.fca_concept_join(self._code, other._code))"
    , "    "
    , "    def implies(self, other: 'Concept') -> 'Concept':"
    , "        \"\"\"Heyting implication (⇨).\"\"\""
    , "        return Concept(_lib.fca_concept_himp(self._code, other._code))"
    , "    "
    , "    @property"
    , "    def name(self) -> str:"
    , "        return _lib.fca_concept_name(self._code).decode('utf-8')"
    , "    "
    , "    def __repr__(self) -> str:"
    , "        return f\"Concept({self.name})\""
    , "    "
    , "    def __eq__(self, other: object) -> bool:"
    , "        return isinstance(other, Concept) and self._code == other._code"
    , ""
    , ""
    , "def verify_all() -> bool:"
    , "    \"\"\"Run verification tests, return True if all pass.\"\"\""
    , "    ctx = FormalContext()"
    , "    "
    , "    # Test 1: Incidence matrix"
    , "    assert ctx.incidence('a', 'X') == True"
    , "    assert ctx.incidence('a', 'Y') == False"
    , "    assert ctx.incidence('b', 'X') == False"
    , "    assert ctx.incidence('b', 'Y') == True"
    , "    "
    , "    # Test 2: Valid concepts"
    , "    assert ctx.is_valid_concept({'a'}, {'X'}) == True"
    , "    assert ctx.is_valid_concept({'b'}, {'Y'}) == True"
    , "    assert ctx.is_valid_concept({'a', 'b'}, set()) == True"
    , "    assert ctx.is_valid_concept(set(), {'X', 'Y'}) == True"
    , "    "
    , "    # Test 3: Invalid concepts"
    , "    assert ctx.is_valid_concept({'a'}, {'X', 'Y'}) == False"
    , "    assert ctx.is_valid_concept({'a'}, {'Y'}) == False"
    , "    "
    , "    # Test 4: Lattice operations"
    , "    left = Concept.left()"
    , "    right = Concept.right()"
    , "    bot = Concept.bot()"
    , "    top = Concept.top()"
    , "    "
    , "    assert (left & right) == bot  # Orthogonal!"
    , "    assert (left | right) == top"
    , "    assert (bot | left) == left"
    , "    "
    , "    # Test 5: Heyting implication"
    , "    assert left.implies(right) == right"
    , "    assert right.implies(left) == left"
    , "    "
    , "    print(\"All verification tests passed!\")"
    , "    return True"
    , ""
    , ""
    , "if __name__ == '__main__':"
    , "    verify_all()"
    , "    "
    , "    # Demo"
    , "    print(\"\\n=== Formal Concept Analysis Demo ===\")"
    , "    ctx = FormalContext()"
    , "    "
    , "    print(f\"\\nIs ({{a}}, {{X}}) a concept? {ctx.is_valid_concept({'a'}, {'X'})}\")"
    , "    print(f\"Is ({{a}}, {{X,Y}}) a concept? {ctx.is_valid_concept({'a'}, {'X', 'Y'})}\")"
    , "    "
    , "    left = Concept.left()"
    , "    right = Concept.right()"
    , "    print(f\"\\nleft ⊓ right = {(left & right).name}\")"
    , "    print(f\"left ⊔ right = {(left | right).name}\")"
    , "    print(f\"left ⇨ right = {left.implies(right).name}\")"
    , ""
    ]

/-! ## CLI Main -/

private partial def parseArgs (args : List String) (cfg : Config := {}) : IO (Config × Bool) :=
  match args with
  | [] => pure (cfg, false)
  | "--" :: rest => parseArgs rest cfg
  | "--help" :: _ => pure (cfg, true)
  | "--out" :: dir :: rest => parseArgs rest { cfg with outDir := dir }
  | "--no-cab" :: rest => parseArgs rest { cfg with generateCAB := false }
  | "--cab" :: rest => parseArgs rest { cfg with generateCAB := true }
  | x :: _ => throw <| IO.userError s!"unknown arg: {x} (try --help)"

private def resolveOutDir (dir : String) : IO System.FilePath := do
  if dir.startsWith "/" then
    return System.FilePath.mk dir
  let cwd ← IO.currentDir
  let base :=
    if cwd.fileName == some "lean" then
      cwd.parent.getD cwd
    else
      cwd
  return base / dir

private def writeFile (path : System.FilePath) (contents : String) : IO Unit := do
  let some parent := path.parent
    | throw <| IO.userError s!"could not compute parent directory for {path}"
  IO.FS.createDirAll parent
  IO.FS.writeFile path contents

def main (argv : List String) : IO UInt32 := do
  try
    let (cfg, showHelp) ← parseArgs argv
    if showHelp then
      IO.println usage
      return (0 : UInt32)

    let outDir ← resolveOutDir cfg.outDir

    writeFile (outDir / "fca.h") headerSource
    writeFile (outDir / "fca.c") sourceCode
    writeFile (outDir / "fca_driver.c") driverSource
    writeFile (outDir / "expected.txt") expectedOutput
    writeFile (outDir / "provenance.json") provenanceJson
    writeFile (outDir / "fca_wrapper.py") pythonWrapper

    IO.println s!"[fca_export] wrote {outDir / "fca.h"}"
    IO.println s!"[fca_export] wrote {outDir / "fca.c"}"
    IO.println s!"[fca_export] wrote {outDir / "fca_driver.c"}"
    IO.println s!"[fca_export] wrote {outDir / "expected.txt"}"
    IO.println s!"[fca_export] wrote {outDir / "provenance.json"}"
    IO.println s!"[fca_export] wrote {outDir / "fca_wrapper.py"}"

    -- Generate CAB certificate if enabled
    if cfg.generateCAB then
      let artifacts : List HeytingLean.Meta.LeanTT0.ExportCAB.Artifact := [
        { name := "fca.h", content := headerSource },
        { name := "fca.c", content := sourceCode },
        { name := "fca_driver.c", content := driverSource },
        { name := "expected.txt", content := expectedOutput },
        { name := "provenance.json", content := provenanceJson },
        { name := "fca_wrapper.py", content := pythonWrapper }
      ]
      let theorems := [
        "FCAComputable.objDeriv_attrDeriv_adjoint",
        "FCAComputable.objClosure_idempotent",
        "FCAComputable.isValidConcept_correct",
        "FCAComputable.conceptMeet_correct",
        "FCAComputable.conceptJoin_correct",
        "Diamond.le_himp_iff"
      ]
      let leanModules := [
        "HeytingLean.Tests.Bridges.ComputableTestKit",
        "HeytingLean.Tests.Bridges.FCAComputable"
      ]
      let certificate := HeytingLean.Meta.LeanTT0.ExportCAB.generateCertificate
        "fca"
        artifacts
        theorems
        leanModules
        "Verified Formal Concept Analysis operations exported to C + Python"
      let certPath := outDir / "certificate.json"
      writeFile certPath (Lean.Json.pretty certificate)
      IO.println s!"[fca_export] wrote {certPath}"

    IO.println ""
    IO.println "To build and test:"
    IO.println s!"  cd {outDir}"
    IO.println "  cc -o fca_driver fca_driver.c fca.c"
    IO.println "  ./fca_driver"
    IO.println "  diff <(./fca_driver) expected.txt && echo 'C VERIFIED OK'"
    IO.println ""
    IO.println "  cc -shared -fPIC -o libfca.so fca.c"
    IO.println "  python3 fca_wrapper.py"
    if cfg.generateCAB then
      IO.println ""
      IO.println "To verify CAB certificate:"
      IO.println s!"  lake exe cab_verify_export {outDir}/certificate.json"

    return (0 : UInt32)
  catch e =>
    IO.eprintln s!"[fca_export] error: {e}"
    return (1 : UInt32)

end FCAExport
end CLI
end HeytingLean

def main (args : List String) : IO UInt32 :=
  HeytingLean.CLI.FCAExport.main args
