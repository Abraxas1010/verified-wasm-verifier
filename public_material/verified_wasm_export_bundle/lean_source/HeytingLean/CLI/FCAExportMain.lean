private def sourceCode : String :=
  String.intercalate "\n"
    [ "/* Formal Concept Analysis - Verified Operations"
    , " * Generated by HeytingLean (fca_export)"
    , " *"
    , " * PROVENANCE: Tables computed in Lean, verified against Heyting algebra axioms."
    , " */"
    , ""
    , "#include \"fca.h\""
    , ""
    , "/* Incidence table (computed in Lean) */"
    , "/*        X  Y */"
    , "/* a */   "
    , "/* b */   "
    , "static const int incidence[2][2] = {"
    , "  {1, 0},  /* a: has X, not Y */"
    , "  {0, 1}   /* b: not X, has Y */"
    , "};"
    , ""
    , "int fca_incidence(int obj, int attr) {"
    , "  if (obj < 0 || obj >= 2 || attr < 0 || attr >= 2) return 0;"
    , "  return incidence[obj][attr];"
    , "}"
    , ""
    , "/* Object derivation: attributes common to all objects in set */"
    , "/* obj_set is bitmask: bit 0 = a, bit 1 = b */"
    , "int fca_obj_deriv(int obj_set) {"
    , "  if (obj_set == 0) return 3;  /* empty set -> all attributes {X,Y} */"
    , "  int result = 3;  /* start with all attributes */"
    , "  for (int obj = 0; obj < 2; obj++) {"
    , "    if (obj_set & (1 << obj)) {"
    , "      for (int attr = 0; attr < 2; attr++) {"
    , "        if (!incidence[obj][attr]) {"
    , "          result &= ~(1 << attr);"
    , "        }"
    , "      }"
    , "    }"
    , "  }"
    , "  return result;"
    , "}"
    , ""
    , "/* Attribute derivation: objects having all attributes in set */"
    , "/* attr_set is bitmask: bit 0 = X, bit 1 = Y */"
    , "int fca_attr_deriv(int attr_set) {"
    , "  if (attr_set == 0) return 3;  /* empty set -> all objects {a,b} */"
    , "  int result = 0;"
    , "  for (int obj = 0; obj < 2; obj++) {"
    , "    int has_all = 1;"
    , "    for (int attr = 0; attr < 2; attr++) {"
    , "      if ((attr_set & (1 << attr)) && !incidence[obj][attr]) {"
    , "        has_all = 0;"
    , "        break;"
    , "      }"
    , "    }"
    , "    if (has_all) result |= (1 << obj);"
    , "  }"
    , "  return result;"
    , "}"
    , ""
    , "/* Closure: G'' = (G')' */"
    , "int fca_obj_closure(int obj_set) {"
    , "  return fca_attr_deriv(fca_obj_deriv(obj_set));"
    , "}"
    , ""
    , "int fca_attr_closure(int attr_set) {"
    , "  return fca_obj_deriv(fca_attr_deriv(attr_set));"
    , "}"
    , ""
    , "/* Check if (obj_set, attr_set) is a valid concept */"
    , "int fca_is_valid_concept(int obj_set, int attr_set) {"
    , "  int actual_intent = fca_obj_deriv(obj_set);"
    , "  int actual_extent = fca_attr_deriv(attr_set);"
    , "  return (actual_intent == attr_set) && (actual_extent == obj_set);"
    , "}"
    , ""
    , "/* Concept meet/join tables (Diamond operations, computed in Lean) */"
    , "static const int meet_table[4][4] = {"
    , "  {0, 0, 0, 0},  /* bot ⊓ * = bot */"
    , "  {0, 1, 0, 1},  /* left ⊓ left = left, left ⊓ right = bot */"
    , "  {0, 0, 2, 2},  /* right ⊓ right = right */"
    , "  {0, 1, 2, 3}   /* top ⊓ * = * */"
    , "};"
    , ""
    , "static const int join_table[4][4] = {"
    , "  {0, 1, 2, 3},  /* bot ⊔ * = * */"
    , "  {1, 1, 3, 3},  /* left ⊔ left = left, left ⊔ right = top */"
    , "  {2, 3, 2, 3},  /* right ⊔ right = right */"
    , "  {3, 3, 3, 3}   /* top ⊔ * = top */"
    , "};"
    , ""
    , "static const int himp_table[4][4] = {"
    , "  {3, 3, 3, 3},  /* bot ⇨ * = top */"
    , "  {2, 3, 2, 3},  /* left ⇨ bot = right, left ⇨ left = top */"
    , "  {1, 1, 3, 3},  /* right ⇨ bot = left */"
    , "  {0, 1, 2, 3}   /* top ⇨ * = * */"
    , "};"
    , ""
    , "int fca_concept_meet(int c1, int c2) {"
    , "  if (c1 < 0 || c1 > 3 || c2 < 0 || c2 > 3) return 0;"
    , "  return meet_table[c1][c2];"
    , "}"
    , ""
    , "int fca_concept_join(int c1, int c2) {"
    , "  if (c1 < 0 || c1 > 3 || c2 < 0 || c2 > 3) return 3;"
    , "  return join_table[c1][c2];"
    , "}"
    , ""
    , "int fca_concept_himp(int c1, int c2) {"
    , "  if (c1 < 0 || c1 > 3 || c2 < 0 || c2 > 3) return 3;"
    , "  return himp_table[c1][c2];"
    , "}"
    , ""
    , "static const char* concept_names[4] = {"
    , "  \"bot (empty extent)\","
    , "  \"left ({a}, {X})\","
    , "  \"right ({b}, {Y})\","
    , "  \"top (full extent)\""
    , "};"
    , ""
    , "const char* fca_concept_name(int c) {"
    , "  if (c < 0 || c > 3) return \"invalid\";"
    , "  return concept_names[c];"
    , "}"
    , ""
    , "/* Map extent bitmask to concept */"
    , "int fca_concept_from_extent(int obj_set) {"
    , "  int closed = fca_obj_closure(obj_set);"
    , "  switch (closed) {"
    , "    case 0: return CONCEPT_BOT;   /* {} */"
    , "    case 1: return CONCEPT_LEFT;  /* {a} */"
    , "    case 2: return CONCEPT_RIGHT; /* {b} */"
    , "    case 3: return CONCEPT_TOP;   /* {a,b} */"
    , "    default: return CONCEPT_BOT;"
    , "  }"
    , "}"
    , ""
    ]

